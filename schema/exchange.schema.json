{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/bitsARK-Labs/exchanges-api/main/schema/exchange.schema.json",
  "title": "Exchange",
  "description": "Schema for a single cryptocurrency exchange entry in the BitsARK Exchanges API.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "slug",
    "website",
    "logo_url",
    "fees",
    "monitored_by_dolarmap",
    "operational_details_br",
    "fiscal_details_br",
    "updated_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique slug-style identifier for the exchange.",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "minLength": 2,
      "maxLength": 64
    },
    "name": {
      "type": "string",
      "description": "Human-readable display name of the exchange.",
      "minLength": 2,
      "maxLength": 128
    },
    "slug": {
      "type": "string",
      "description": "URL-safe slug for the exchange (should match id).",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "minLength": 2,
      "maxLength": 64
    },
    "website": {
      "type": "string",
      "description": "Official website URL of the exchange.",
      "format": "uri"
    },
    "logo_url": {
      "type": "string",
      "description": "URL of the exchange logo image.",
      "format": "uri"
    },
    "operational_details_br": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cnpj", "bcb_authorized", "accepts_pix", "main_jurisdiction"],
      "properties": {
        "cnpj": {
          "oneOf": [
            { "type": "string", "pattern": "^\\d{2}\\.\\d{3}\\.\\d{3}/\\d{4}-\\d{2}$" },
            { "type": "null" }
          ]
        },
        "bcb_authorized": { "type": "boolean" },
        "accepts_pix": { "type": "boolean" },
        "main_jurisdiction": {
          "type": "string",
          "enum": ["Brasil", "Offshore", "Internacional com Presença no Brasil"]
        }
      }
    },
    "fiscal_details_br": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tax_regime",
        "monthly_brl_trade_exemption",
        "exchange_rfb_reports",
        "user_rfb_action_monthly"
      ],
      "properties": {
        "tax_regime": {
          "type": "string",
          "enum": [
            "domestic_exchange",
            "domestic_exchange_foreign_origin",
            "offshore_law_14754"
          ]
        },
        "monthly_brl_trade_exemption": {
          "type": "number",
          "description": "Exemption limit in BRL for monthly sales."
        },
        "exchange_rfb_reports": {
          "type": "array",
          "items": { "enum": ["in_1888_monthly", "decripto_annually"] }
        },
        "user_rfb_action_monthly": {
          "type": "array",
          "items": {
            "enum": ["manual_report_over_30k_traded", "manual_darf_over_15k_profit"]
          }
        }
      }
    },
    "fees": {
      "type": "object",
      "description": "Trading fee information.",
      "additionalProperties": false,
      "required": [
        "maker",
        "taker",
        "fee_url",
        "note"
      ],
      "properties": {
        "maker": {
          "type": "number",
          "description": "Maker fee as a decimal (e.g., 0.001 = 0.1%).",
          "minimum": 0,
          "maximum": 1
        },
        "taker": {
          "type": "number",
          "description": "Taker fee as a decimal (e.g., 0.001 = 0.1%).",
          "minimum": 0,
          "maximum": 1
        },
        "fee_url": {
          "type": "string",
          "description": "Direct URL to the exchange's official fee schedule page.",
          "format": "uri"
        },
        "note": {
          "type": "string",
          "description": "Human-readable note about fees, discounts, or special conditions.",
          "maxLength": 512
        }
      }
    },
    "monitored_by_dolarmap": {
      "type": "boolean",
      "description": "Whether this exchange is actively monitored by the DolarMap service."
    },
    "fiscal_status_br": {
      "type": "string",
      "description": "Classification of the exchange from a Brazilian fiscal perspective (Nacional, Internacional com Presença no Brasil, Internacional).",
      "enum": [
        "Nacional",
        "Internacional com Presença no Brasil",
        "Internacional"
      ]
    },
    "updated_at": {
      "type": "string",
      "description": "ISO 8601 datetime when this entry was last manually verified.",
      "format": "date-time"
    }
  }
}
